# Скопируйте в .env и заполните токен от @BotFather
BOT_TOKEN=123456:replace_me
DATABASE_URL=postgresql://quiz:quiz_password@postgres:5432/quiz_bot

# Пул соединений PostgreSQL для нагрузки
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=30

# Секрет для webhook-режима. В polling-режиме не используется.
WEBHOOK_SECRET=change-me-long-random-secret
